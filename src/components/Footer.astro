---
import lion from "../assets/lion-mark.png";
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---
<footer class="border-t border-bone/10 py-14">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
    <div class="grid md:grid-cols-[1.4fr_1fr_1fr] gap-10">
      <div>
        <a href="#top" class="flex items-center gap-3 mb-4">
          <img src={lion.src} width="40" height="40" alt="" class="w-10 h-10" />
          <span class="font-display font-semibold text-[16px] text-bone">Beast Marketing Co</span>
        </a>
        <p class="text-ash text-[14px] leading-[1.6] max-w-[24rem]">
          One team. One voice. Your entire marketing and custom apparel, handled, for businesses in
          Sarasota and Bradenton.
        </p>
      </div>

      <div>
        <p class="text-[12px] font-medium uppercase tracking-[0.14em] text-ash mb-4">Explore</p>
        <ul class="space-y-2.5 text-[14px] text-bone/90">
          <li><a href="#services" class="hover:text-rose transition-colors">Services</a></li>
          <li><a href="#packages" class="hover:text-rose transition-colors">Packages</a></li>
          <li><a href="#about" class="hover:text-rose transition-colors">About</a></li>
          <li><a href="#faq" class="hover:text-rose transition-colors">FAQ</a></li>
          <li><a href="#quote" class="hover:text-rose transition-colors">Request a quote</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[12px] font-medium uppercase tracking-[0.14em] text-ash mb-4">Get in touch</p>
        <ul class="space-y-2.5 text-[14px] text-bone/90">
          <li><a href="tel:+12402410423" class="hover:text-rose transition-colors">240-241-0423</a></li>
          <li><a href="mailto:Beastmarketingco@gmail.com" class="hover:text-rose transition-colors break-words">Beastmarketingco@gmail.com</a></li>
          <li class="text-ash">Sarasota / Bradenton, FL</li>
          <li class="text-ash">By appointment</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-bone/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-[13px] text-ash">
      <p>&copy; {year} Beast Marketing Co. All rights reserved.</p>
      <a href={`${base}/privacy`} class="hover:text-bone transition-colors">Privacy</a>
    </div>
  </div>
</footer>
