---
const serviceOptions = [
  "Branding & logo", "Website", "Social media", "Email marketing",
  "Paid ads", "SEO & local search", "Custom apparel", "AI & automation", "Not sure yet",
];
const budgets = [
  "Under $1,000 (one project)",
  "$1,000 to $3,500 per month",
  "$4,000+ per month",
  "Not sure yet",
];
---
<section id="quote" class="py-24 lg:py-28 border-t border-bone/10">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10 grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-16">
    <!-- Left: the ask + fallback -->
    <div class="reveal">
      <h2 class="font-display font-semibold text-bone text-[clamp(2rem,4vw,3rem)] leading-[1.05] tracking-[-0.01em]">
        Get a straight answer on price.
      </h2>
      <p class="text-ash text-[1.0625rem] leading-[1.65] mt-5 max-w-[30rem]">
        Tell us a little about your business and what you need. You will get a clear, no-pressure quote
        back, usually within one business day.
      </p>
      <div class="mt-9 space-y-3">
        <a href="tel:+12402410423" class="flex items-center gap-3 text-bone hover:text-rose transition-colors">
          <svg class="w-5 h-5 text-rose" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2"/></svg>
          <span class="text-[15px]">Call or text 240-241-0423</span>
        </a>
        <a href="mailto:brianna@beastmarketing.pro" class="flex items-center gap-3 text-bone hover:text-rose transition-colors">
          <svg class="w-5 h-5 text-rose" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          <span class="text-[15px]">brianna@beastmarketing.pro</span>
        </a>
        <p class="flex items-center gap-3 text-ash">
          <svg class="w-5 h-5 text-ash" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="11" r="3"/><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7"/></svg>
          <span class="text-[15px]">Serving Sarasota, Bradenton, and Lakewood Ranch</span>
        </p>
      </div>
    </div>

    <!-- Right: the form -->
    <div class="reveal rounded-[10px] border border-bone/10 bg-surface/60 p-7 lg:p-9">
      <form id="quote-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
        <input type="hidden" name="access_key" value="REPLACE_WITH_WEB3FORMS_ACCESS_KEY" />
        <input type="hidden" name="subject" value="New quote request from beastmarketing.pro" />
        <input type="hidden" name="from_name" value="Beast Marketing website" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid sm:grid-cols-2 gap-5">
          <div class="flex flex-col gap-2">
            <label for="name" class="text-[14px] font-medium text-bone">Your name</label>
            <input id="name" name="name" type="text" required autocomplete="name"
              class="h-11 rounded-[10px] bg-obsidian/60 border border-bone/15 px-3.5 text-[15px] text-bone placeholder:text-ash focus:border-rose outline-none transition-colors"
              placeholder="First and last" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="business" class="text-[14px] font-medium text-bone">Business name</label>
            <input id="business" name="business" type="text" autocomplete="organization"
              class="h-11 rounded-[10px] bg-obsidian/60 border border-bone/15 px-3.5 text-[15px] text-bone placeholder:text-ash focus:border-rose outline-none transition-colors"
              placeholder="Your business" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class="text-[14px] font-medium text-bone">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email"
              class="h-11 rounded-[10px] bg-obsidian/60 border border-bone/15 px-3.5 text-[15px] text-bone placeholder:text-ash focus:border-rose outline-none transition-colors"
              placeholder="you@business.com" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="phone" class="text-[14px] font-medium text-bone">Phone <span class="text-ash font-normal">(optional)</span></label>
            <input id="phone" name="phone" type="tel" autocomplete="tel"
              class="h-11 rounded-[10px] bg-obsidian/60 border border-bone/15 px-3.5 text-[15px] text-bone placeholder:text-ash focus:border-rose outline-none transition-colors"
              placeholder="(941) 000-0000" />
          </div>
        </div>

        <fieldset class="flex flex-col gap-3">
          <legend class="text-[14px] font-medium text-bone mb-1">What do you need? Pick any that fit.</legend>
          <div class="flex flex-wrap gap-2.5">
            {serviceOptions.map((s) => (
              <label class="cursor-pointer">
                <input type="checkbox" name="services" value={s} class="peer sr-only" />
                <span class="inline-block text-[14px] text-ash border border-bone/15 rounded-full px-3.5 py-1.5 transition-colors peer-checked:bg-rose peer-checked:text-obsidian peer-checked:border-rose peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-rose hover:border-bone/30">{s}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <div class="flex flex-col gap-2">
          <label for="budget" class="text-[14px] font-medium text-bone">Rough budget</label>
          <select id="budget" name="budget"
            class="h-11 rounded-[10px] bg-obsidian/60 border border-bone/15 px-3.5 text-[15px] text-bone focus:border-rose outline-none transition-colors">
            <option value="" class="bg-obsidian">Select a range</option>
            {budgets.map((b) => <option value={b} class="bg-obsidian">{b}</option>)}
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="text-[14px] font-medium text-bone">Anything else?</label>
          <textarea id="message" name="message" rows="4"
            class="rounded-[10px] bg-obsidian/60 border border-bone/15 px-3.5 py-3 text-[15px] text-bone placeholder:text-ash focus:border-rose outline-none transition-colors resize-y"
            placeholder="Tell us what is going on with your marketing right now."></textarea>
        </div>

        <button type="submit"
          class="w-full font-medium text-[15px] text-obsidian bg-rose px-6 py-3.5 rounded-[10px] hover:bg-rose-pressed active:scale-[0.99] transition-all">
          Request a quote
        </button>
        <p id="form-status" role="status" aria-live="polite" class="text-[14px] text-ash text-center min-h-[1.25rem]"></p>
        <p class="text-[13px] text-ash leading-[1.5] text-center">
          We use your details only to reply to you. See our <a href="/privacy" class="underline hover:text-bone">privacy note</a>.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const key = (form.querySelector('[name="access_key"]') as HTMLInputElement)?.value;
      if (!key || key.startsWith("REPLACE_")) {
        status.textContent = "Form not connected yet. Please call or text 240-241-0423 for now.";
        status.style.color = "#FF7A1A";
        return;
      }
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = "Sending...";
      status.textContent = "";
      try {
        const res = await fetch(form.action, { method: "POST", body: new FormData(form), headers: { Accept: "application/json" } });
        if (res.ok) {
          form.reset();
          status.textContent = "Thanks. Your request is in. We will reply within one business day.";
          status.style.color = "#16C6A4";
        } else {
          throw new Error();
        }
      } catch {
        status.textContent = "Something went wrong. Please call or text 240-241-0423.";
        status.style.color = "#FF7A1A";
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  }
</script>
