---
import Base from "../layouts/Base.astro";
import lion from "../assets/lion-mark.png";

const title = "Beast Marketing | By appointment only";
const description =
  "A one stop marketing and custom apparel team. Taking new clients by appointment only. Call or text 240-241-0423.";
---

<Base title={title} description={description}>
  <main class="relative min-h-[100dvh] overflow-hidden flex items-center justify-center">
    <div class="relative z-10 mx-auto w-full max-w-[680px] px-6 py-16 sm:py-20 flex flex-col items-center text-center">
      <!-- Brand mark: static spectrum lion with halo + slow hue-drift -->
      <div class="relative w-[clamp(12rem,44vw,19rem)] aspect-square flex items-center justify-center mb-9 sm:mb-11">
        <div class="lion-halo absolute inset-0 rounded-full blur-3xl opacity-60"
             style="background: radial-gradient(closest-side, rgba(255,58,94,0.55), rgba(123,63,228,0.35) 55%, rgba(46,125,255,0.18) 75%, transparent 85%);"></div>
        <img src={lion.src} width="431" height="431" alt="Beast Marketing spectrum lion mark"
             class="lion-drift relative z-10 w-full h-full object-contain drop-shadow-[0_24px_60px_rgba(0,0,0,0.5)]" fetchpriority="high" />
      </div>

      <p class="reveal-up font-display font-semibold text-bone tracking-[0.01em] text-[clamp(1.2rem,3.4vw,1.55rem)] mb-5" style="--d:.10s">
        Beast Marketing
      </p>

      <h1 class="reveal-up font-display font-semibold text-bone leading-[1.05] tracking-[-0.02em] text-[clamp(2.25rem,5.6vw,3.75rem)]" style="--d:.18s">
        Taking new clients <span class="text-rose">by appointment</span> only.
      </h1>

      <p class="reveal-up text-ash text-[1.0625rem] leading-[1.65] mt-6 max-w-[46ch]" style="--d:.28s">
        One local team for your entire marketing and custom apparel. Brand, website, social,
        ads, and merch, handled. Our full site is on its way. Want to get started now? Let's set up a time.
      </p>

      <div class="reveal-up flex flex-col sm:flex-row items-center gap-3 mt-9 w-full sm:w-auto" style="--d:.38s">
        <a href="tel:+12402410423"
           class="w-full sm:w-auto font-medium text-[15px] text-obsidian bg-rose px-6 py-3.5 rounded-[10px] hover:bg-rose-pressed active:scale-[0.98] transition-all">
          Call or text 240-241-0423
        </a>
        <a href="mailto:brianna@beastmarketing.pro"
           class="w-full sm:w-auto font-medium text-[15px] text-bone px-6 py-3.5 rounded-[10px] border border-bone/20 hover:border-rose hover:bg-rose/10 transition-all break-words">
          brianna@beastmarketing.pro
        </a>
      </div>

      <p class="reveal-up text-[12px] font-medium uppercase tracking-[0.14em] text-ash mt-10" style="--d:.50s">
        By appointment only
      </p>
    </div>

    <div class="spectrum-rule absolute bottom-0 inset-x-0 h-px opacity-40"></div>
  </main>
</Base>

<style>
  @keyframes revealUp {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: none; }
  }
  .reveal-up {
    opacity: 0;
    animation: revealUp 0.75s cubic-bezier(0.16, 1, 0.3, 1) var(--d, 0s) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-up { opacity: 1; animation: none; }
  }
</style>
